# ------------------------------------------------------------------
# SOMA Competition Portal - Environment Variables
# Copy this file to ".env.local" and fill in your real Supabase values.
# ------------------------------------------------------------------

# Found in Supabase: Project Settings -> API -> Project URL
NEXT_PUBLIC_SUPABASE_URL=

# Found in Supabase: Project Settings -> API -> Project API keys -> anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Found in Supabase: Project Settings -> API -> Project API keys -> service_role
# WARNING: This is a SECRET. Never share it. It is only used on the server.
SUPABASE_SERVICE_ROLE_KEY=

# The address your site runs on. Locally this is http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# The name of the Supabase Storage bucket used for question images.
NEXT_PUBLIC_SUPABASE_IMAGE_BUCKET=question-images
